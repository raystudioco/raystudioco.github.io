source "https://rubygems.org"

gem "jekyll", "~> 4.2"
gem "kramdown-parser-gfm"  # required by Jekyll 4 for GFM markdown
gem "jekyll-paginate"       # required for paginate: 5 in _config.yml
gem "jekyll-sitemap"        # generates /sitemap.xml automatically
gem "webrick"               # required in Ruby 3.x (not in stdlib)
